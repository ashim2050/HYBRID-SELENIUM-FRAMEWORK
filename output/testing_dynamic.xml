<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="HybridFramework_DynamicSuite" parallel="false" thread-count="2" verbose="1">
    <listeners>
        <listener class-name="com.framework.listeners.TestListener"/>
    </listeners>
    <test name="Login Tests" preserve-order="true">
        <classes>
            <class name="com.framework.tests.LoginTests"/>
        </classes>
    </test>
    <test name="Search Tests" preserve-order="true">
        <classes>
            <class name="com.framework.tests.SearchTests"/>
        </classes>
    </test>
    <test name="API Tests" preserve-order="true">
        <classes>
            <class name="com.framework.tests.ApiDataDrivenTests"/>
        </classes>
    </test>
</suite>
